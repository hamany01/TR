rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for users
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Rules for usernames
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for events
    match /events/{eventId} {
      allow read, write: if request.auth != null;
    }

    // Rules for reminder templates
    match /reminder_templates/{templateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for reminder logs
    match /reminder_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Rules for debug and queues
    match /debug_notifications/{docId} {
      allow read, write: if request.auth != null;
    }
    match /desktop_queue/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
